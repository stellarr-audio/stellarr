# Copy this file to .env and fill in your values.
# .env files are gitignored and never committed.

# Sentry DSN for crash reporting (optional — Sentry won't init without it)
VITE_SENTRY_DSN=

# Sentry environment (defaults to "development" if not set)
VITE_SENTRY_ENV=development

# App version (defaults to "dev" if not set)
VITE_APP_VERSION=dev
